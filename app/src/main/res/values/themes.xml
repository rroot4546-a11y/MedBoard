<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MedBoard" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="Theme.MedBoard.Splash" parent="Theme.MedBoard">
        <item name="android:windowBackground">@color/primary</item>
    </style>

    <style name="Theme.MedBoard.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="SectionCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>
</resources>
