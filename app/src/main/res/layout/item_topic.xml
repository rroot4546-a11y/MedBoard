<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp" android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp" app:cardElevation="1dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">

        <View android:id="@+id/colorBar" android:layout_width="4dp" android:layout_height="40dp"
            android:background="@color/primary" />

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
            <TextView android:id="@+id/tvTitle" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" />
            <TextView android:id="@+id/tvSubtitle" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginTop="2dp"
                android:maxLines="2" android:ellipsize="end" />
        </LinearLayout>

        <ImageView android:id="@+id/ivCached" android:layout_width="20dp" android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_save" android:visibility="gone" android:layout_marginEnd="4dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="›" android:textSize="20sp" android:textColor="@color/text_light" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
