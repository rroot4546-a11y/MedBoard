<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".MedBoardApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MedBoard">

        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MedBoard.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false" />

        <activity
            android:name=".ui.topics.SystemTopicsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.detail.TopicDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ui.bookmarks.BookmarksActivity"
            android:exported="false" />

        <activity
            android:name=".ui.search.SearchActivity"
            android:exported="false" />

    </application>

</manifest>
